{{/*
Build Kerberos principal
Usage: {{ include "kerberos.principal" (dict "ctx" . "service" "scm") }}
       {{ include "kerberos.principal" (dict "ctx" . "service" "HTTP_scm") }}
*/}}
{{- define "kerberos.principal" -}}
{{- $glob := .ctx.Values.global.security.kerberos -}}
{{- $service := .service -}}
{{- $subdomain := .service -}}

{{- if hasPrefix "HTTP_" .service -}}
  {{- $service = "HTTP" -}}
  {{- $subdomain = trimPrefix "HTTP_" .service -}}
{{- end -}}

{{- $p := $glob.principal.pattern -}}
{{- $p = replace "{{ .Service }}" $service $p -}}
{{- $p = replace "{{ .Subdomain }}" $subdomain $p -}}
{{- replace "{{ .Realm }}" $glob.realm $p -}}
{{- end -}}






        rangerCaKey: ""
        fluentbitCaKey: ""
        prometheusRwCaKey: ""
        federateCaKey: ""
