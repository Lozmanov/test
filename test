package main

import (
	"log"
	"os"
	"os/exec"
	"syscall"
)

func main() {
	hueHome := os.Getenv("HUE_HOME")
	if hueHome == "" {
		hueHome = "/usr/share/hue"
	}

	if err := os.Chdir(hueHome); err != nil {
		log.Fatalf("chdir %s: %v", hueHome, err)
	}

	python := hueHome + "/build/env/bin/python"
	hueScript := hueHome + "/build/env/bin/hue"
	supervisorScript := hueHome + "/build/env/bin/supervisor"
	migrate := exec.Command(python, hueScript, "migrate")
	migrate.Stdout = os.Stdout
	migrate.Stderr = os.Stderr
	migrate.Stdin = os.Stdin
	if err := migrate.Run(); err != nil {
		log.Printf("warning: hue migrate: %v", err)
	}

	if err := syscall.Exec(python, []string{python, supervisorScript}, os.Environ()); err != nil {
		log.Fatalf("exec supervisor: %v", err)
	}
}













