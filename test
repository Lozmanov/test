{{- if and .Values.recon.enabled .Values.recon.auth.enabled }}
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ include "ozone.fullname" . }}-recon-nginx
  namespace: {{ include "ozone.namespace" . }}
  labels:
    {{- include "ozone.labels" . | nindent 4 }}
    app.kubernetes.io/component: ozone-recon
data:
  nginx.conf: |
    worker_processes auto;
    error_log /dev/stderr warn;
    pid /tmp/nginx.pid;

    events {
      worker_connections 1024;
    }

    http {
      client_body_temp_path /tmp/client_temp;
      proxy_temp_path       /tmp/proxy_temp;
      fastcgi_temp_path     /tmp/fastcgi_temp;
      uwsgi_temp_path       /tmp/uwsgi_temp;
      scgi_temp_path        /tmp/scgi_temp;

      access_log /dev/stdout combined;

      server {
        listen 19888;
        server_name _;

        location / {
          auth_basic "Ozone Recon";
          auth_basic_user_file /tmp/htpasswd;
          proxy_pass http://127.0.0.1:{{ .Values.recon.service.port }};
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
          proxy_http_version 1.1;
          proxy_set_header Upgrade $http_upgrade;
          proxy_set_header Connection "upgrade";
        }
      }
    }
{{- end }}
