-Dhadoop.log.dir={{ $.ctx.Values.fluentBit.logDir }} -Dhadoop.log.file={{ .component }}.log -Dlog4j.configurationFile={{ join "," $configs }} -Dlog4j2.contextSelector=org.apache.logging.log4j.core.async.AsyncLoggerContextSelector
