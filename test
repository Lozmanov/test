package main

import (
	"fmt"
	"log"
	"os"
	"os/exec"
	"strings"
	"syscall"
)

func main() {
	hueHome := os.Getenv("HUE_HOME")
	if hueHome == "" {
		hueHome = "/usr/share/hue"
	}

	if err := os.Chdir(hueHome); err != nil {
		log.Fatalf("chdir %s: %v", hueHome, err)
	}

	if pwFile := os.Getenv("HUE_DB_PASSWORD_FILE"); pwFile != "" {
		data, err := os.ReadFile(pwFile)
		if err != nil {
			log.Fatalf("read HUE_DB_PASSWORD_FILE %s: %v", pwFile, err)
		}
		password := strings.TrimRight(string(data), "\r\n")
		overrideIni := fmt.Sprintf("[desktop]\n  [[database]]\n    password=%s\n", password)
		overridePath := hueHome + "/desktop/conf/zz-db-password.ini"
		if err := os.WriteFile(overridePath, []byte(overrideIni), 0600); err != nil {
			log.Fatalf("write db password override: %v", err)
		}
	}

	if skFile := os.Getenv("HUE_SECRET_KEY_FILE"); skFile != "" {
		data, err := os.ReadFile(skFile)
		if err != nil {
			log.Fatalf("read HUE_SECRET_KEY_FILE %s: %v", skFile, err)
		}
		secretKey := strings.TrimRight(string(data), "\r\n")
		overrideIni := fmt.Sprintf("[desktop]\n  secret_key=%s\n", secretKey)
		overridePath := hueHome + "/desktop/conf/zz-secret-key.ini"
		if err := os.WriteFile(overridePath, []byte(overrideIni), 0600); err != nil {
			log.Fatalf("write secret key override: %v", err)
		}
	}

	python := hueHome + "/build/env/bin/python"
	hueScript := hueHome + "/build/env/bin/hue"
	supervisorScript := hueHome + "/build/env/bin/supervisor"
	migrate := exec.Command(python, hueScript, "migrate")
	migrate.Stdout = os.Stdout
	migrate.Stderr = os.Stderr
	migrate.Stdin = os.Stdin
	if err := migrate.Run(); err != nil {
		log.Printf("warning: hue migrate: %v", err)
	}

	if err := syscall.Exec(python, []string{python, supervisorScript}, os.Environ()); err != nil {
		log.Fatalf("exec supervisor: %v", err)
	}
}
