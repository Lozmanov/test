# Patch rules for production Helm chart artifact generation.
#
# Each rule describes one substitution to make in the chart templates:
#   name        — human-readable label (shown in script output)
#   files       — list of glob patterns relative to chart root
#                 (works for templates/ AND values.yaml - any file in the chart)
#   search      — exact string to find (must match literally, including whitespace)
#   replacement — how to compute the replacement text:
#                   • plain string with {path.to.value} — resolved from merged values;
#                     supports tpl-resolution of {{ .Values.* }} refs inside values
#                   • {path1 || path2}                  — coalesce: first non-empty wins
#                     (mirrors Helm's {{ coalesce .Values.X .Values.Y }})
#                   • type: yaml_value                  — renders values subtree as YAML
#                     block with specified indent (mirrors Helm's toYaml | nindent N)
#                   • type: literal + value: |           — exact multi-line text,
#                     no substitution; use this for complex expressions (range, etc.)
#
# Rules are applied in order. A [MISS] warning means the search string was not found
# (normal for disabled optional components). A [SKIP] means value resolution failed.
#
# To patch ConfigMap content: target values.yaml or templates/configmap.yaml.
# Simple {{ .Values.X }} expressions in values.yaml are auto-resolved.
# Complex range/if blocks require type: literal with pre-rendered content.
#
# The top-level `remove:` list (see bottom of file) deletes files/directories
# from the release artifact entirely — used to drop optional components that must
# not ship in the production distributive (hue, recon). Patterns are globs
# relative to the chart root, same convention as a patch's `files`. Removal runs
# as the final step, after all patches are applied.

# ── Paths excluded from the release artifact ──────────────────────────────────
# hue и recon не должны попадать в релизный дистрибутив — удаляем их шаблоны
# целиком (values-секции остаются безвредными при enabled=false).
remove:
  - templates/hue
  - templates/recon

patches:

  # ── Images ──────────────────────────────────────────────────────────────────

  - name: om image
    files:
      - templates/om/statefulset.yaml
    search: 'image: "{{ $.Values.global.image.registry }}/{{ tpl $.Values.om.image.repository $ }}:{{ tpl $.Values.om.image.tag $ }}"'
    replacement: 'image: {global.image.registry}/{om.image.repository}:{om.image.tag}'

  - name: scm image
    files:
      - templates/scm/statefulset.yaml
    search: 'image: "{{ $.Values.global.image.registry }}/{{ tpl $.Values.scm.image.repository $ }}:{{ tpl $.Values.scm.image.tag $ }}"'
    replacement: 'image: {global.image.registry}/{scm.image.repository}:{scm.image.tag}'

  - name: datanode image
    files:
      - templates/datanode/statefulset.yaml
    search: 'image: "{{ $.Values.global.image.registry }}/{{ tpl $.Values.datanode.image.repository $ }}:{{ tpl $.Values.datanode.image.tag $ }}"'
    replacement: 'image: {global.image.registry}/{datanode.image.repository}:{datanode.image.tag}'

  - name: s3g image
    files:
      - templates/s3g/deployment.yaml
    search: 'image: "{{ .Values.global.image.registry }}/{{ tpl .Values.s3g.image.repository . }}:{{ tpl .Values.s3g.image.tag . }}"'
    replacement: 'image: {global.image.registry}/{s3g.image.repository}:{s3g.image.tag}'

  - name: recon image
    files:
      - templates/recon/deployment.yaml
    search: 'image: "{{ .Values.global.image.registry }}/{{ tpl .Values.recon.image.repository . }}:{{ tpl .Values.recon.image.tag . }}"'
    replacement: 'image: {global.image.registry}/{recon.image.repository}:{recon.image.tag}'

  - name: cli image
    files:
      - templates/cli/deployment.yaml
    search: 'image: "{{ .Values.global.image.registry }}/{{ tpl .Values.cli.image.repository . }}:{{ tpl .Values.cli.image.tag . }}"'
    replacement: 'image: {global.image.registry}/{cli.image.repository}:{cli.image.tag}'

  - name: prometheus image
    files:
      - templates/prometheus/deployment.yaml
    search: 'image: "{{ .Values.global.image.registry }}/{{ tpl .Values.prometheus.image.repository . }}:{{ tpl .Values.prometheus.image.tag . }}"'
    replacement: 'image: {global.image.registry}/{prometheus.image.repository}:{prometheus.image.tag}'

  - name: prometheus service account name
    files:
      - templates/prometheus/deployment.yaml
      - templates/prometheus/rbac.yaml
    search: '{{ .Values.prometheus.serviceAccount.name }}'
    replacement: '{prometheus.serviceAccount.name}'

  # Optional components (disabled by default; patches applied only if files matched)

  - name: hue image
    files:
      - templates/hue/deployment.yaml
    search: 'image: "{{ coalesce .Values.hue.image.registry .Values.global.image.registry }}/{{ .Values.hue.image.repository }}:{{ .Values.hue.image.tag }}"'
    replacement: 'image: {hue.image.registry || global.image.registry}/{hue.image.repository}:{hue.image.tag}'

  - name: hivemetastore image
    files:
      - templates/hivemetastore/deployment.yaml
    # ВАЖНО: после перевода HMS sts→deploy шаблон использует $.Values (не .Values).
    search: 'image: "{{ coalesce $.Values.hiveMetastore.image.registry $.Values.global.image.registry }}/{{ $.Values.hiveMetastore.image.repository }}:{{ $.Values.hiveMetastore.image.tag }}"'
    replacement: 'image: {hiveMetastore.image.registry || global.image.registry}/{hiveMetastore.image.repository}:{hiveMetastore.image.tag}'

  - name: fluentbit image
    files:
      - templates/_helpers.tpl
    search: '  image: "{{ tpl $ctx.Values.fluentBit.image.registry $ctx }}/{{ tpl $ctx.Values.fluentBit.image.repository $ctx }}:{{ tpl $ctx.Values.fluentBit.image.tag $ctx }}"'
    replacement: '  image: "{fluentBit.image.registry}/{fluentBit.image.repository}:{fluentBit.image.tag}"'

  - name: metallb image
    files:
      - templates/datanode/statefulset.yaml
    search: 'image: "{{ $.Values.global.image.registry }}/{{ tpl $.Values.metalLb.image.repository $ }}:{{ tpl $.Values.metalLb.image.tag $ }}"'
    replacement: 'image: {global.image.registry}/{metalLb.image.repository}:{metalLb.image.tag}'

  # ── Pod Security Context ─────────────────────────────────────────────────────
  # Replaces: {{- include "ozone.podSecurityContext" $ | nindent 6 }}
  # Source values: global.podSecurityContext

  - name: pod security context
    files:
      - templates/om/statefulset.yaml
      - templates/scm/statefulset.yaml
      - templates/datanode/statefulset.yaml
      - templates/s3g/deployment.yaml
      - templates/recon/deployment.yaml
      - templates/cli/deployment.yaml
      - templates/hue/deployment.yaml
      - templates/hivemetastore/deployment.yaml
      - templates/prometheus/deployment.yaml
      - templates/istio/ingressgateway/deployment.yaml
      - templates/istio/egressgateway/deployment.yaml
    search: '      {{- include "ozone.podSecurityContext" $ | nindent 6 }}'
    replacement:
      type: yaml_value
      key: global.podSecurityContext
      prefix: 'securityContext:'
      indent: 6

  # ── Container Security Context ───────────────────────────────────────────────
  # Replaces: {{- include "ozone.containerSecurityContext" $ | nindent 10 }}
  # Source values: global.securityContext

  - name: container security context
    files:
      - templates/om/statefulset.yaml
      - templates/scm/statefulset.yaml
      - templates/datanode/statefulset.yaml
      - templates/s3g/deployment.yaml
      - templates/recon/deployment.yaml
      - templates/cli/deployment.yaml
      - templates/hue/deployment.yaml
      - templates/hivemetastore/deployment.yaml
      - templates/prometheus/deployment.yaml
      - templates/istio/ingressgateway/deployment.yaml
      - templates/istio/egressgateway/deployment.yaml
    search: '          {{- include "ozone.containerSecurityContext" $ | nindent 10 }}'
    replacement:
      type: yaml_value
      key: global.securityContext
      prefix: 'securityContext:'
      indent: 10

  # ── ConfigMap examples ──────────────────────────────────────────────────────
  # The ConfigMap is rendered via: {{- tpl (toYaml .Values.configuration.files) $ | nindent 4 }}
  # To hardcode its content, target either templates/configmap.yaml or values.yaml directly.
  #
  # Example 1: simple {{ .Values.X }} expression in values.yaml — auto-resolved via {path}.
  # Uncomment and fill in the exact production value.
  #
  # - name: scm primordial node
  #   files:
  #     - values.yaml
  #   search: '          <value>{{ .Values.scm.primordialNode }}</value>'
  #   replacement: '          <value>scm0</value>'
  #
  # Example 2: OM nodes list — contains range/if, cannot be auto-resolved.
  # Use type: literal and provide the fully expanded XML fragment manually.
  #
  # - name: om nodes list (literal)
  #   files:
  #     - values.yaml
  #   search: '          <value>{{ range $i := until (int .Values.om.replicas) }}{{ if $i }},{{ end }}om{{ $i }}{{ end }}</value>'
  #   replacement:
  #     type: literal
  #     value: '          <value>om0,om1,om2</value>'
  #
  # Example 3: replace the entire configmap data block for full control.
  # Obtain the fully rendered content with:
  #   helm template helm-charts/ozone -f values/values-ift.yaml | yq 'select(.kind=="ConfigMap") | .data'
  #
  # - name: configmap data (fully hardcoded)
  #   files:
  #     - templates/configmap.yaml
  #   search: '  {{- tpl (toYaml .Values.configuration.files) $ | nindent 4 }}'
  #   replacement:
  #     type: literal
  #     value: |
  #       core-site.xml: |-
  #         ... full XML content ...
  #       ozone-site.xml: |-
  #         ... full XML content ...
