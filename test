{{- if .Values.recon.auth.enabled }}
        - name: recon-auth-proxy
          image: {{ .Values.recon.auth.image }}
          securityContext:
            allowPrivilegeEscalation: false
            runAsNonRoot: true
            runAsUser: 101
            seccompProfile:
              type: RuntimeDefault
            capabilities:
              drop:
                - ALL
          command:
            - sh
            - -c
            - |
              until [ -f {{ .Values.recon.auth.secretPaths.username }} ] && [ -f {{ .Values.recon.auth.secretPaths.password }} ]; do
                sleep 1
              done
              printf '%s:%s\n' \
                "$(cat {{ .Values.recon.auth.secretPaths.username }})" \
                "$(openssl passwd -apr1 "$(cat {{ .Values.recon.auth.secretPaths.password }})")" \
                > /tmp/htpasswd
              exec nginx -g 'daemon off;'
          ports:
            - containerPort: 19888
              name: ui-proxy
          volumeMounts:
            - name: recon-nginx-config
              mountPath: /etc/nginx/nginx.conf
              subPath: nginx.conf
        {{- end }}




{{- if .Values.recon.auth.enabled }}
        - name: recon-nginx-config
          configMap:
            name: {{ include "ozone.fullname" . }}-recon-nginx
        {{- end }}


syncPort: 9891
  # Arbitrary annotations added to the recon pod (e.g. Vault agent inject annotations).
  podAnnotations: {}
  auth:
    # Enable HTTP Basic Auth in front of the Recon UI via an nginx sidecar proxy.
    # Credentials are read from files injected by vault-agent (no Kubernetes Secrets).
    # When enabled, Service port 9888 is routed through nginx (port 19888).
    # Health probes still hit recon directly on 9888 and bypass authentication.
    enabled: false
    # Non-root nginx image with openssl and sh (uid 101).
    image: "nginxinc/nginx-unprivileged:alpine"
    # Paths where vault-agent writes the plaintext username and password files.
    secretPaths:
      username: /vault/secrets/recon-username
      password: /vault/secrets/recon-password




targetPort: {{ if .Values.recon.auth.enabled }}19888{{ else }}{{ .Values.recon.service.port }}{{ end }}


