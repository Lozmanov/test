# ── 3c. bash (для отладки: kubectl exec в scratch-под) ───────────────────────
echo ">>> bash"
BASH_BIN="$(command -v bash 2>/dev/null || true)"
if [ -n "$BASH_BIN" ]; then
    real="$(readlink -f "$BASH_BIN")"
    mkdir -p "${ROOTFS}$(dirname "$real")"
    [ -f "${ROOTFS}${real}" ] || cp -p "$real" "${ROOTFS}${real}"
    echo "  copied ${real}"
    ldd "$real" 2>/dev/null | awk '/=>/ {print $3} NF==2 && /^\// {print $1}' | while read -r lib; do
        [ -f "$lib" ] || continue
        mkdir -p "${ROOTFS}$(dirname "$lib")"
        [ -f "${ROOTFS}${lib}" ] || cp -p "$lib" "${ROOTFS}${lib}"
    done || true
    # удобные точки входа: /bin/bash и /usr/bin/bash → реальный бинарь
    for p in /bin/bash /usr/bin/bash; do
        [ -e "${ROOTFS}${p}" ] || { mkdir -p "${ROOTFS}$(dirname "$p")"; ln -sf "$real" "${ROOTFS}${p}"; }
    done
else
    echo "  WARNING: bash не найден в билдере"
fi
