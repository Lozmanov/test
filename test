# ── 3b. coreutils: du / df ───────────────────────────────────────────────────
echo ">>> coreutils (du, df)"
for tool in du df; do
    bin="$(command -v "$tool" 2>/dev/null || true)"
    if [ -z "$bin" ]; then
        echo "  WARNING: ${tool} не найден в билдере"
        continue
    fi
    real="$(readlink -f "$bin")"
    # реальный бинарь (например /usr/bin/coreutils) + его .so (для static — пусто)
    copy_with_deps "$real"
    # пересоздаём симлинк tool -> real, если tool был симлинком (coreutils-single)
    if [ "$bin" != "$real" ]; then
        mkdir -p "${ROOTFS}$(dirname "$bin")"
        ln -sf "$real" "${ROOTFS}${bin}"
        echo "  symlink ${bin} -> ${real}"
    fi
done
