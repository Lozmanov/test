{{- if .Values.prometheus.enabled }}
{{- $ns := include "ozone.namespace" . }}
kind: ConfigMap
apiVersion: v1
metadata:
  name: {{ include "ozone.fullname" . }}-prometheus-root-config
  namespace: {{ include "ozone.namespace" . }}
  labels:
    {{- include "ozone.labels" . | nindent 4 }}
    app.kubernetes.io/component: ozone-prometheus
data:
  prometheus.yml: |
    global:
      scrape_interval: 1m
      scrape_timeout: 30s
      evaluation_interval: 1m
      external_labels:
        remote_write_id: {{ .Values.prometheus.remoteWriteId }}
        prometheus_name: {{ .Release.Name }}
        prometheus_replica: {{ .Release.Name }}
        system: {{ .Values.global.clusterName | default .Release.Name }}
        namespace: {{ $ns }}
    rule_files:
      - /prometheus/config/record_rules.yml
    scrape_configs:
      - job_name: 'prometheus'
        metrics_path: /metrics
        static_configs:
        - targets: ['localhost:9090']
        relabel_configs:
        - source_labels: [__address__]
          separator: ;
          regex: ^(.*):\d+$
          target_label: instance
          replacement: {{ .Release.Name }}
          action: replace
        - source_labels: [__address__]
          separator: ;
          regex: ^(.*):(\d+)$
          target_label: port
          replacement: $2
          action: replace

      {{- if .Values.prometheus.federate.enabled }}
      {{- $fedExclude := "" }}
      {{- with .Values.prometheus.federate.excludeJobs }}
      {{- $fedExclude = printf `, job!~"(%s)"` (join "|" .) }}
      {{- end }}
      - job_name: federate
        honor_labels: true
        honor_timestamps: true
        params:
          match[]:
            - '{namespace="{{ $ns }}"{{ $fedExclude }}}'
            {{- range .Values.prometheus.federate.namespaces }}
            - '{namespace="{{ . }}"{{ $fedExclude }}}'
            {{- end }}
        scrape_interval: {{ .Values.prometheus.federate.scrapeInterval }}
        scrape_timeout: {{ .Values.prometheus.federate.scrapeTimeout }}
        metrics_path: /federate
        scheme: https
        static_configs:
          - targets:
              - {{ regexReplaceAll "^https?://" .Values.prometheus.federate.url "" | quote }}
        bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
        tls_config:
          ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
          insecure_skip_verify: false
        metric_relabel_configs:
          - regex: prometheus_replica
            action: labeldrop
          - regex: prometheus
            action: labeldrop
      {{- end }}

      {{- $dom := .Values.global.clusterDomain }}
      {{/* StatefulSet-компоненты скрейпятся per-pod по СТАБИЛЬНОМУ FQDN
           (<pod>.<svc>.<ns>.svc.<domain>), а НЕ по pod IP: тогда authority
           совпадает с vhost сервиса (*.<svc>...) → запрос роутится в mTLS-кластер
           (DR ozone-mtls / auto-mTLS) и STRICT-таргет его принимает. Скрейп по
           pod IP под REGISTRY_ONLY уходит в blackhole. */}}
      {{- $stsTargets := list }}
      {{- if .Values.om.enabled }}{{- $stsTargets = append $stsTargets (dict "comp" .Values.om.component "svc" .Values.om.serviceName "port" .Values.om.service.port) }}{{- end }}
      {{- if .Values.scm.enabled }}{{- $stsTargets = append $stsTargets (dict "comp" .Values.scm.component "svc" .Values.scm.serviceName "port" .Values.scm.service.port) }}{{- end }}
      {{- if .Values.datanode.enabled }}{{- $stsTargets = append $stsTargets (dict "comp" .Values.datanode.component "svc" .Values.datanode.serviceName "port" .Values.datanode.service.port) }}{{- end }}
      {{- range $t := $stsTargets }}
      - job_name: {{ $t.comp }}
        kubernetes_sd_configs:
          - role: pod
            namespaces:
              names:
                - {{ $ns }}
        relabel_configs:
          - source_labels: [__meta_kubernetes_pod_label_component]
            action: keep
            regex: {{ $t.comp }}
          - source_labels: [__meta_kubernetes_pod_phase]
            action: drop
            regex: Pending|Succeeded|Failed|Completed
          - source_labels: [__meta_kubernetes_pod_name]
            action: replace
            regex: (.+)
            replacement: ${1}.{{ $t.svc }}.{{ $ns }}.svc.{{ $dom }}:{{ $t.port }}
            target_label: __address__
          - target_label: __metrics_path__
            replacement: /prom
          - source_labels: [__meta_kubernetes_pod_label_component]
            action: replace
            target_label: job
          - source_labels: [__meta_kubernetes_namespace]
            action: replace
            target_label: namespace
          - source_labels: [__meta_kubernetes_pod_name]
            action: replace
            target_label: pod
          - source_labels: [__meta_kubernetes_pod_node_name]
            action: replace
            target_label: node
      {{- end }}

      {{/* Deployment/ClusterIP-компоненты: скрейп по FQDN сервиса (роутится через
           VIP в mTLS-кластер). recon — 1 реплика (== per-pod); s3g агрегируется
           по репликам (стабильного per-pod DNS у Deployment нет). */}}
      {{- $svcTargets := list }}
      {{- if .Values.recon.enabled }}{{- $svcTargets = append $svcTargets (dict "comp" .Values.recon.component "host" (printf "%s.%s.svc.%s" .Values.recon.serviceName $ns $dom) "port" .Values.recon.service.port) }}{{- end }}
      {{- if .Values.s3g.enabled }}{{- $svcTargets = append $svcTargets (dict "comp" .Values.s3g.component "host" (printf "%s-rest.%s.svc.%s" .Values.s3g.serviceName $ns $dom) "port" .Values.s3g.service.rest.port) }}{{- end }}
      {{- range $t := $svcTargets }}
      - job_name: {{ $t.comp }}
        metrics_path: /prom
        static_configs:
          - targets: ['{{ $t.host }}:{{ $t.port }}']
            labels:
              namespace: {{ $ns }}
      {{- end }}

      {{/* Istio-гейтвеи: только envoy-статы на :15020 (plaintext по дизайну),
           стабильный job= для record rules ниже. */}}
      {{- $gateways := list }}
      {{- if .Values.istio.ingressGateway.enabled }}{{- $gateways = append $gateways (dict "job" "ingressgateway" "label" .Values.istio.ingressGateway.selectorLabel) }}{{- end }}
      {{- if .Values.istio.egressGateway.enabled }}{{- $gateways = append $gateways (dict "job" "egressgateway" "label" .Values.istio.egressGateway.selectorLabel) }}{{- end }}
      {{- range $gw := $gateways }}
      - job_name: {{ $gw.job }}
        honor_labels: true
        kubernetes_sd_configs:
          - role: pod
            namespaces:
              names:
                - {{ $ns }}
        relabel_configs:
          - source_labels: [__meta_kubernetes_pod_label_istio]
            action: keep
            regex: {{ $gw.label }}
          - source_labels: [__meta_kubernetes_pod_phase]
            action: drop
            regex: Pending|Succeeded|Failed|Completed
          - source_labels: [__meta_kubernetes_pod_ip]
            action: replace
            regex: (.+)
            replacement: $1:15020
            target_label: __address__
          - target_label: __metrics_path__
            replacement: /stats/prometheus
          - source_labels: [__meta_kubernetes_namespace]
            action: replace
            target_label: namespace
          - source_labels: [__meta_kubernetes_pod_name]
            action: replace
            target_label: pod
          - source_labels: [__meta_kubernetes_pod_node_name]
            action: replace
            target_label: node
      {{- end }}

    remote_write:
      {{- range .Values.prometheus.remoteWrite }}
      - {{- toYaml . | nindent 8 }}
        {{- if or $.Values.prometheus.dropMetrics $.Values.prometheus.dropLabels }}
        write_relabel_configs:
          {{- with $.Values.prometheus.dropMetrics }}
          - source_labels: [__name__]
            regex: '({{ join "|" . }})'
            action: drop
          {{- end }}
          {{- with $.Values.prometheus.dropLabels }}
          - regex: '({{ join "|" . }})'
            action: labeldrop
          {{- end }}
        {{- end }}
      {{- end }}

  record_rules.yml: |-
    groups:
    {{- $svcs := list (dict "name" "recon" "svc" .Values.recon.serviceName) (dict "name" "s3g" "svc" (printf "%s-rest" .Values.s3g.serviceName)) (dict "name" "hue" "svc" .Values.hue.serviceName) (dict "name" "prometheus" "svc" .Values.prometheus.serviceName) }}
    {{- range $s := $svcs }}
    - name: ozone-{{ $s.name }}-istio
      rules:
      - record: ozone:istio_rps_{{ $s.name }}:1m
        expr: sum(rate(istio_requests_total{destination_service_name="{{ $s.svc }}",job="ingressgateway"}[1m]))
      - record: ozone:istio_error_perc_{{ $s.name }}:1m
        expr: |
          100 *
          (sum(rate(istio_requests_total{destination_service_name="{{ $s.svc }}",job="ingressgateway",response_code=~"5.."}[1m])) or on() vector(0))
          /
          (sum(rate(istio_requests_total{destination_service_name="{{ $s.svc }}",job="ingressgateway"}[1m])) + 1)
      - record: ozone:istio_duration_p99_{{ $s.name }}:5m
        expr: |
          histogram_quantile(0.99,
            sum(rate(istio_request_duration_milliseconds_bucket{destination_service_name="{{ $s.svc }}",job="ingressgateway"}[5m]))
          by (le))
    {{- end }}
{{- end }}














{{- if and .Values.istio.enabled .Values.prometheus.enabled }}
{{- $ns := include "ozone.namespace" . }}
{{/*
  Заставляет sidecar Prometheus делать mTLS-origination на сервисы namespace.
  Prometheus скрейпит компоненты по их FQDN (см. prometheus/configmap.yaml) —
  authority совпадает с vhost сервиса и трафик роутится в mTLS-кластер, где эта
  DR включает ISTIO_MUTUAL. STRICT сохраняется, plaintext-дыр нет.
*/}}
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: {{ include "ozone.fullname" . }}-mtls
  namespace: {{ $ns }}
  labels:
    {{- include "ozone.labels" . | nindent 4 }}
spec:
  host: "*.{{ $ns }}.svc.{{ .Values.global.clusterDomain }}"
  trafficPolicy:
    tls:
      mode: ISTIO_MUTUAL
{{- end }}
