{{- if and .Values.istio.enabled .Values.prometheus.enabled .Values.prometheus.apiServerCIDR }}
---
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: {{ include "ozone.fullname" . }}-kubernetes-api
  namespace: {{ include "ozone.namespace" . }}
  labels:
    {{- include "ozone.labels" . | nindent 4 }}
spec:
  host: kubernetes-api.cluster.local
  trafficPolicy:
    tls:
      mode: PASSTHROUGH
{{- end }}




{{- if and .Values.prometheus.enabled .Values.prometheus.apiServerCIDR }}
{{- $apiServerIP := .Values.prometheus.apiServerCIDR | trimSuffix "/32" }}
{{- if $apiServerIP }}
---
apiVersion: networking.istio.io/v1beta1
kind: ServiceEntry
metadata:
  name: {{ include "ozone.fullname" . }}-kubernetes-api
  namespace: {{ include "ozone.namespace" . }}
  labels:
    {{- include "ozone.labels" . | nindent 4 }}
spec:
  hosts:
    - kubernetes-api.cluster.local
  addresses:
    - {{ $apiServerIP }}/32
  ports:
    - number: 443
      name: tls-kubernetes-api
      protocol: TLS
  resolution: NONE
  location: MESH_EXTERNAL
{{- end }}
{{- end }}

