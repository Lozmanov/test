{{- if and .Values.istio.enabled .Values.prometheus.enabled }}
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: {{ include "ozone.fullname" . }}-kubernetes-api
  namespace: {{ include "ozone.namespace" . }}
  labels:
    {{- include "ozone.labels" . | nindent 4 }}
spec:
  host: kubernetes.default.svc.{{ .Values.global.clusterDomain }}
  trafficPolicy:
    tls:
      mode: DISABLE
{{- end }}
