{{- if .Values.prometheus.enabled }}
{{- $ns := include "ozone.namespace" . }}
kind: ConfigMap
apiVersion: v1
metadata:
  name: {{ include "ozone.fullname" . }}-prometheus-root-config
  namespace: {{ include "ozone.namespace" . }}
  labels:
    {{- include "ozone.labels" . | nindent 4 }}
    app.kubernetes.io/component: ozone-prometheus
data:
  prometheus.yml: |
    global:
      scrape_interval: 1m
      scrape_timeout: 30s
      evaluation_interval: 1m
      external_labels:
        remote_write_id: {{ .Values.prometheus.remoteWriteId }}
        prometheus_name: {{ .Release.Name }}
        prometheus_replica: {{ .Release.Name }}
        system: {{ .Values.global.clusterName | default .Release.Name }}
        namespace: {{ $ns }}
    rule_files:
      - /prometheus/config/record_rules.yml
    scrape_configs:
      - job_name: 'prometheus'
        metrics_path: /metrics
        static_configs:
        - targets: ['localhost:9090']
        relabel_configs:
        - source_labels: [__address__]
          separator: ;
          regex: ^(.*):\d+$
          target_label: instance
          replacement: {{ .Release.Name }}
          action: replace
        - source_labels: [__address__]
          separator: ;
          regex: ^(.*):(\d+)$
          target_label: port
          replacement: $2
          action: replace

      {{- if .Values.prometheus.federate.enabled }}
      {{- $fedExclude := "" }}
      {{- with .Values.prometheus.federate.excludeJobs }}
      {{- $fedExclude = printf `, job!~"(%s)"` (join "|" .) }}
      {{- end }}
      - job_name: federate
        honor_labels: true
        honor_timestamps: true
        params:
          match[]:
            - '{namespace="{{ $ns }}"{{ $fedExclude }}}'
            {{- range .Values.prometheus.federate.namespaces }}
            - '{namespace="{{ . }}"{{ $fedExclude }}}'
            {{- end }}
        scrape_interval: {{ .Values.prometheus.federate.scrapeInterval }}
        scrape_timeout: {{ .Values.prometheus.federate.scrapeTimeout }}
        metrics_path: /federate
        scheme: https
        static_configs:
          - targets:
              - {{ regexReplaceAll "^https?://" .Values.prometheus.federate.url "" | quote }}
        bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
        tls_config:
          ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
          insecure_skip_verify: false
        metric_relabel_configs:
          - regex: prometheus_replica
            action: labeldrop
          - regex: prometheus
            action: labeldrop
      {{- end }}

      - job_name: 'kubernetes-pods'
        kubernetes_sd_configs:
          - role: pod
            namespaces:
              names:
                - {{ $ns }}
        relabel_configs:
          - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_scrape]
            action: keep
            regex: "true"
          # Gateways expose only envoy stats and are handled by the dedicated
          # ingressgateway/egressgateway jobs below (stable job= label for the
          # record rules) — keep them out of this app-metrics job.
          - source_labels: [__meta_kubernetes_pod_label_istio]
            action: drop
            regex: (.+)
          - source_labels: [__meta_kubernetes_pod_phase]
            action: drop
            regex: Pending|Succeeded|Failed|Completed
          # Scrape the istio prometheus-merge endpoint :15020/stats/prometheus,
          # NOT the app port directly. With enablePrometheusMerge=true istio reads
          # each pod's prometheus.io/port+path (9874//prom …) to scrape the app
          # internally and merges it into envoy stats on :15020. istio does NOT
          # overwrite our pre-set annotations, so we force 15020 here instead of
          # reading prometheus.io/port. 15020 is exempt from mTLS interception →
          # scrape stays in-mesh, STRICT intact, no excludeInboundPorts needed.
          # (The app prometheus.io/port+path annotations are kept as the merge
          # source for istio — do not remove them.)
          - source_labels: [__meta_kubernetes_pod_ip]
            action: replace
            regex: (.+)
            replacement: $1:15020
            target_label: __address__
          - action: replace
            target_label: __metrics_path__
            replacement: /stats/prometheus
          - source_labels: [__meta_kubernetes_pod_label_component]
            action: replace
            target_label: job
            regex: (.+)
          - source_labels: [__meta_kubernetes_namespace]
            action: replace
            target_label: namespace
          - source_labels: [__meta_kubernetes_pod_name]
            action: replace
            target_label: pod
          - source_labels: [__meta_kubernetes_pod_node_name]
            action: replace
            target_label: node

      {{/* Dedicated jobs for the istio gateways: envoy-only stats on
           :15020/stats/prometheus, with a stable job= label (ingressgateway /
           egressgateway) used by the record rules below. */}}
      {{- $gateways := list }}
      {{- if .Values.istio.ingressGateway.enabled }}
      {{- $gateways = append $gateways (dict "job" "ingressgateway" "label" .Values.istio.ingressGateway.selectorLabel) }}
      {{- end }}
      {{- if .Values.istio.egressGateway.enabled }}
      {{- $gateways = append $gateways (dict "job" "egressgateway" "label" .Values.istio.egressGateway.selectorLabel) }}
      {{- end }}
      {{- range $gw := $gateways }}
      - job_name: {{ $gw.job }}
        honor_labels: true
        kubernetes_sd_configs:
          - role: pod
            namespaces:
              names:
                - {{ $ns }}
        relabel_configs:
          - source_labels: [__meta_kubernetes_pod_label_istio]
            action: keep
            regex: {{ $gw.label }}
          - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_scrape]
            action: keep
            regex: "true"
          - source_labels: [__meta_kubernetes_pod_phase]
            action: drop
            regex: Pending|Succeeded|Failed|Completed
          - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_path]
            action: replace
            target_label: __metrics_path__
            regex: (.+)
          # IPv6 endpoint: [addr]:port
          - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_port, __meta_kubernetes_pod_ip]
            action: replace
            regex: (\d+);(([A-Fa-f0-9]{1,4}::?){1,7}[A-Fa-f0-9]{1,4})
            replacement: '[$2]:$1'
            target_label: __address__
          # IPv4 endpoint: addr:port
          - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_port, __meta_kubernetes_pod_ip]
            action: replace
            regex: (\d+);((([0-9]+?)(\.|$)){4})
            replacement: $2:$1
            target_label: __address__
          - source_labels: [__meta_kubernetes_namespace]
            action: replace
            target_label: namespace
          - source_labels: [__meta_kubernetes_pod_name]
            action: replace
            target_label: pod
          - source_labels: [__meta_kubernetes_pod_node_name]
            action: replace
            target_label: node
      {{- end }}

    remote_write:
      {{- range .Values.prometheus.remoteWrite }}
      - {{- toYaml . | nindent 8 }}
        {{- if or $.Values.prometheus.dropMetrics $.Values.prometheus.dropLabels }}
        write_relabel_configs:
          {{- with $.Values.prometheus.dropMetrics }}
          - source_labels: [__name__]
            regex: '({{ join "|" . }})'
            action: drop
          {{- end }}
          {{- with $.Values.prometheus.dropLabels }}
          - regex: '({{ join "|" . }})'
            action: labeldrop
          {{- end }}
        {{- end }}
      {{- end }}

  record_rules.yml: |-
    groups:
    # L7 metrics are taken from the istio ingress gateway scrape (job=ingressgateway),
    # not from per-pod sidecars (app pods are scraped on /prom only now).
    # destination_canonical_service is "ozone" for every component, so services are
    # distinguished by destination_service_name.
    {{- $svcs := list (dict "name" "recon" "svc" .Values.recon.serviceName) (dict "name" "s3g" "svc" (printf "%s-rest" .Values.s3g.serviceName)) (dict "name" "hue" "svc" .Values.hue.serviceName) (dict "name" "prometheus" "svc" .Values.prometheus.serviceName) }}
    {{- range $s := $svcs }}
    - name: ozone-{{ $s.name }}-istio
      rules:
      - record: ozone:istio_rps_{{ $s.name }}:1m
        expr: sum(rate(istio_requests_total{destination_service_name="{{ $s.svc }}",job="ingressgateway"}[1m]))
      - record: ozone:istio_error_perc_{{ $s.name }}:1m
        expr: |
          100 *
          (sum(rate(istio_requests_total{destination_service_name="{{ $s.svc }}",job="ingressgateway",response_code=~"5.."}[1m])) or on() vector(0))
          /
          (sum(rate(istio_requests_total{destination_service_name="{{ $s.svc }}",job="ingressgateway"}[1m])) + 1)
      - record: ozone:istio_duration_p99_{{ $s.name }}:5m
        expr: |
          histogram_quantile(0.99,
            sum(rate(istio_request_duration_milliseconds_bucket{destination_service_name="{{ $s.svc }}",job="ingressgateway"}[5m]))
          by (le))
    {{- end }}
{{- end }}

