{{/*
Istio sidecar injection annotation.
Outputs sidecar.istio.io/inject: "true" when istio.enabled and istio.injection.enabled are both true.
Usage: {{- include "ozone.istioAnnotations" . | nindent 8 }}
*/}}
{{/*
Generate ingress host for a component.
If ingress.host is explicitly set — use it as-is.
Otherwise auto-generate: {component}-ozone-{namespace}.{global.ingress.baseDomain}

Usage:
  {{ include "ozone.ingress.host" (dict "host" .Values.recon.ingress.host "component" .Values.recon.serviceName "ctx" .) }}
*/}}
{{- define "ozone.ingress.host" -}}
{{- if .host -}}
  {{- .host -}}
{{- else -}}
  {{- printf "%s-ozone-%s.%s" .component (include "ozone.namespace" .ctx) .ctx.Values.global.ingress.baseDomain -}}
{{- end -}}
{{- end -}}

{{/*
Vault Agent annotations for kerberos keytab (base64-encoded).
Injects /vault/secrets/{component}-keytab-b64 from the Vault KV path.
Usage: {{- include "ozone.kerberosAnnotations" (dict "ctx" $ "component" "scm") | nindent 8 }}
*/}}
{{- define "ozone.kerberosAnnotations" -}}
{{- $ctx := .ctx -}}
{{- $component := .component -}}
{{- if and $ctx.Values.secman.enabled $ctx.Values.global.security.kerberos.enabled -}}
{{- $vaultKey := index $ctx.Values.global.security.kerberos.vaultKeys $component -}}
vault.hashicorp.com/agent-inject-secret-{{ $component }}-keytab-b64: 'true'
vault.hashicorp.com/agent-inject-template-{{ $component }}-keytab-b64: |
  {{`{{- with secret `}}"{{ $ctx.Values.secman.path }}"{{` -}}`}}
  {{`{{ .Data.`}}{{ $vaultKey }}{{` }}`}}
  {{`{{- end }}`}}
vault.hashicorp.com/agent-inject-perms-{{ $component }}-keytab-b64: '0644'
{{- end -}}
{{- end -}}

{{/*
VolumeMount для krb5.conf из отдельного ConfigMap.
Usage: {{- include "ozone.krb5VolumeMount" . | nindent 12 }}
*/}}
{{- define "ozone.krb5VolumeMount" -}}
{{- if .Values.global.security.kerberos.enabled }}
- name: krb5-config
  mountPath: /etc/krb5.conf
  subPath: krb5.conf
  readOnly: true
{{- end }}
{{- end -}}

{{/*
Volume krb5-config — отдельный ConfigMap с krb5.conf.
Usage: {{- include "ozone.krb5Volume" . | nindent 8 }}
*/}}
{{- define "ozone.krb5Volume" -}}
{{- if .Values.global.security.kerberos.enabled }}
- name: krb5-config
  configMap:
    name: {{ include "ozone.fullname" . }}-krb5-config
{{- end }}
{{- end -}}

{{- define "ozone.istioAnnotations" -}}
{{- if and .Values.istio.enabled .Values.istio.injection.enabled }}
sidecar.istio.io/inject: "true"
proxy.istio.io/config: '{"holdApplicationUntilProxyStarts": true}'
{{- end }}
{{- end -}}

{{/*
Базовые vault-agent annotations. Caller отвечает за решение, нужны ли
они для этого pod'а (см. inline проверки "vault-нужен-для-этого-pod"
в templates). При отсутствии реальных inject'ов их добавлять нельзя —
иначе vault-injector webhook отвергает pod из-за отсутствия SA token mount.
Usage: {{- include "ozone.secmanAnnotations" . | nindent 8 }}
*/}}
{{- define "ozone.secmanAnnotations" -}}
vault.hashicorp.com/namespace: {{ .Values.secman.namespace }}
vault.hashicorp.com/role: {{ .Values.secman.role | default (include "ozone.namespace" .) }}
vault.hashicorp.com/agent-inject: 'true'
