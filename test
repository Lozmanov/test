{{- if and .Values.istio.enabled .Values.istio.egressGateway.enabled }}
{{- $sel  := .Values.istio.egressGateway.selectorLabel }}
{{- $ns   := include "ozone.namespace" . }}
{{- $dom  := .Values.global.clusterDomain }}
{{- $gwSvc := printf "istio-egressgateway-%s.%s.svc.%s" $sel $ns $dom }}
{{- $gwRef := printf "%s/%s-egressgateway" $ns (include "ozone.fullname" .) }}
{{- $caFiles := .Values.istio.egressGateway.tls.caFiles }}
{{- $caSecman := .Values.istio.egressGateway.tls.secman }}

{{/*
  Маршрутизация трафика через Egress Gateway. Существует два класса целей:

  ── HTTP origination ────────────────────────────────────────────────────
  Приложение шлёт plain HTTP внутрь mesh; sidecar → egress по mTLS; на
  egress выполняется mTLS origination к настоящему внешнему HTTPS-серверу:
  клиентский cert+key и CA для проверки цепочки upstream'а лежат только
  на egress pod'е и выпускаются одной выдачей движка SBERCA (см.
  ozone.egressGateway.vaultAnnotations). Это единственный паттерн, который
  реально переносит хранение CA из app pod на gateway. Используется для
  Ranger, prometheus remoteWrite/federate, fluentbit.

  ── TLS passthrough ─────────────────────────────────────────────────────
  Приложение шлёт TLS-байты (HTTPS/JDBC SSL); sidecar → egress по mTLS,
  на egress снимается mTLS-обёртка и оригинальный TLS-поток пробрасывается
  до upstream без терминации. CA остаётся в pod'е (Java truststore или
  системный cacerts). Используется для secman/Vault, fluentbit, PostgreSQL.
*/}}

{{/* ────────────── HTTP-origination targets ────────────── */}}
{{- $httpTargets := list }}
{{- if and .Values.ranger.enabled .Values.ranger.policyAdminUrl }}
  {{- $h := regexReplaceAll "^https?://([^/:?#]+).*" .Values.ranger.policyAdminUrl "$1" }}
  {{- $upPort := 443 }}
  {{- if regexMatch ":[0-9]+" .Values.ranger.policyAdminUrl }}
    {{- $upPort = .Values.ranger.policyAdminUrl | regexFind ":[0-9]+" | trimPrefix ":" | int }}
  {{- end }}
  {{- if $h }}
    {{- $httpTargets = append $httpTargets (dict "name" "ranger" "host" $h "upstreamPort" $upPort "appPort" 80 "listener" 8443 "mtls" $caSecman.rangerMtls "caKey" $caSecman.rangerCaKey "upstreamCaFile" "/vault/secrets/egressgateway-ranger-upstream-ca") }}
  {{- end }}
{{- end }}
{{/*
  Каждый prometheus.remoteWrite[] (если URL http://) уходит через egress
  с TLS origination. Реальный HTTPS upstream port вычисляется из URL
  (если без явного порта — считаем 443).
*/}}
{{- if .Values.prometheus.enabled }}
{{- range $idx, $rw := .Values.prometheus.remoteWrite }}
  {{- if $rw.url }}
  {{- $h := regexReplaceAll "^https?://([^/:?#]+).*" $rw.url "$1" }}
  {{- $upPort := 443 }}
  {{- if regexMatch "^https?://[^/:?#]+:[0-9]+" $rw.url }}
    {{- $portStr := regexReplaceAll "^https?://[^/:?#]+:([0-9]+).*" $rw.url "$1" }}
    {{- $upPort = int $portStr }}
  {{- end }}
  {{- if $h }}
    {{- $name := printf "prom-rw-%d" $idx }}
    {{- $httpTargets = append $httpTargets (dict "name" $name "host" $h "upstreamPort" $upPort "appPort" 80 "listener" 8443 "mtls" $caSecman.prometheusRwMtls "caKey" $caSecman.prometheusRwCaKey "upstreamCaFile" "/vault/secrets/egressgateway-prometheus-rw-upstream-ca") }}
  {{- end }}
  {{- end }}
{{- end }}
{{- end }}
{{/*
  fluentbit sidecar шлёт plain HTTP на restlogsHost:restlogsPort — sidecar
  ловит как HTTP, egress делает TLS origination к настоящему HTTPS
  collector. appPort = restlogsPort (тот же, на который шлёт fluentbit
  внутри mesh; ServiceEntry объявляет его HTTP). upstreamPort тоже =
  restlogsPort (это и есть HTTPS-порт реального сервера).
*/}}
{{- if and .Values.fluentBit.enabled .Values.fluentBit.restlogsHost }}
  {{- $port := int .Values.fluentBit.restlogsPort }}
  {{- $httpTargets = append $httpTargets (dict "name" "fluentbit" "host" .Values.fluentBit.restlogsHost "upstreamPort" $port "appPort" $port "listener" 8443 "mtls" $caSecman.fluentbitMtls "caKey" $caSecman.fluentbitCaKey "upstreamCaFile" "/vault/secrets/egressgateway-fluentbit-upstream-ca") }}
{{- end }}
{{/*
  Prometheus federate target — внешний cluster-wide Prometheus,
  с которого тянем метрики через /federate. HTTP в mesh, HTTPS upstream.
*/}}
{{- if and .Values.prometheus.enabled .Values.prometheus.federate.enabled .Values.prometheus.federate.url }}
  {{- $h := regexReplaceAll "^https?://([^/:?#]+).*" .Values.prometheus.federate.url "$1" }}
  {{- $appPort := 9090 }}
  {{- if regexMatch ":[0-9]+" .Values.prometheus.federate.url }}
    {{- $appPort = .Values.prometheus.federate.url | regexFind ":[0-9]+" | trimPrefix ":" | int }}
  {{- end }}
  {{- $upPort := 443 }}
  {{- if $h }}
    {{- $httpTargets = append $httpTargets (dict "name" "prom-federate" "host" $h "upstreamPort" $upPort "appPort" $appPort "listener" 8443 "mtls" $caSecman.federateMtls "caKey" $caSecman.federateCaKey "upstreamCaFile" "/vault/secrets/egressgateway-federate-upstream-ca") }}
  {{- end }}
{{- end }}

{{/* ────────────── TLS-passthrough targets ────────────── */}}
{{- $tlsTargets := list }}
{{- if and .Values.secman.enabled .Values.secman.hostname }}
  {{- $tlsTargets = append $tlsTargets (dict "name" "secman" "host" .Values.secman.hostname "port" 443 "listener" 8444) }}
{{- end }}

{{/* ────────────── PostgreSQL (TCP+TLS passthrough) ────────────── */}}
{{- $pgTargets := list }}
{{- if and .Values.hue.enabled .Values.hue.database.host }}
  {{- $h := include "ozone.externalDbHost" .Values.hue.database.host }}
  {{- $pgTargets = append $pgTargets (dict "name" "pg-hue" "host" $h "port" (int .Values.hue.database.port)) }}
{{- end }}
{{- if and .Values.hiveMetastore.enabled .Values.hiveMetastore.database.host }}
  {{- $h := include "ozone.externalDbHost" .Values.hiveMetastore.database.host }}
  {{- $sameAsHue := and .Values.hue.enabled (eq $h (include "ozone.externalDbHost" .Values.hue.database.host)) (eq (int .Values.hiveMetastore.database.port) (int .Values.hue.database.port)) }}
  {{- if not $sameAsHue }}
    {{- $pgTargets = append $pgTargets (dict "name" "pg-hms" "host" $h "port" (int .Values.hiveMetastore.database.port)) }}
  {{- end }}
{{- end }}

{{/* ════════════════════════════════════════════════════════
     HTTP-origination resources (Ranger и т.п.)
   ════════════════════════════════════════════════════════ */}}
{{- range $t := $httpTargets }}
---
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: {{ include "ozone.fullname" $ }}-egress-to-{{ $t.name }}
  namespace: {{ $ns }}
  labels:
    {{- include "ozone.labels" $ | nindent 4 }}
spec:
  host: {{ $gwSvc }}
  subsets:
    - name: {{ $t.name }}
      trafficPolicy:
        portLevelSettings:
          - port:
              number: {{ $t.listener }}
            tls:
              mode: ISTIO_MUTUAL
              sni: {{ $t.host | quote }}
---
{{/*
  TLS origination на upstream HTTPS-сервер. mtls=true (и secman включён) →
  MUTUAL: общая для всех upstream'ов тройка клиентский cert+key+CA
  (issuing_ca) из одной выдачи SBERCA с CN = свой домен gateway, файлы
  монтирует Vault Agent (см. ozone.egressGateway.vaultAnnotations).
  Иначе — SIMPLE с insecureSkipVerify (только для dev/test без Vault,
  в prod mtls обязателен).

  workloadSelector обязателен: без него DR применяется ко всем sidecar'ам,
  у которых хост в egress-scope, и их SDS падает на чтении
  /vault/secrets/egressgateway-* (файлы есть только на gateway pod'е).
*/}}
{{- $mutual := and $t.mtls $.Values.secman.enabled }}
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: {{ include "ozone.fullname" $ }}-ext-{{ $t.name }}-tls
  namespace: {{ $ns }}
  labels:
    {{- include "ozone.labels" $ | nindent 4 }}
spec:
  host: {{ $t.host | quote }}
  workloadSelector:
    matchLabels:
      istio: {{ $sel }}
  trafficPolicy:
    portLevelSettings:
      - port:
          number: {{ $t.upstreamPort }}
        tls:
          mode: {{ if $mutual }}MUTUAL{{ else }}SIMPLE{{ end }}
          sni: {{ $t.host | quote }}
          {{- if $mutual }}
          clientCertificate: {{ $caFiles.clientCert | quote }}
          privateKey: {{ $caFiles.clientKey | quote }}
          {{- if $t.caKey }}
          caCertificates: {{ $t.upstreamCaFile | quote }}
          {{- else }}
          caCertificates: {{ $caFiles.ca | quote }}
          {{- end }}
          {{- else }}
          insecureSkipVerify: true
          {{- end }}
---
apiVersion: networking.istio.io/v1beta1
kind: VirtualService
metadata:
  name: {{ include "ozone.fullname" $ }}-egress-{{ $t.name }}
  namespace: {{ $ns }}
  labels:
    {{- include "ozone.labels" $ | nindent 4 }}
spec:
  hosts:
    - {{ $t.host | quote }}
  gateways:
    - mesh
    - {{ $gwRef }}
  http:
    - match:
        - port: {{ $t.appPort }}
          gateways:
            - mesh
      route:
        - destination:
            host: {{ $gwSvc }}
            subset: {{ $t.name }}
            port:
              number: {{ $t.listener }}
    - match:
        - port: {{ $t.listener }}
          gateways:
            - {{ $gwRef }}
      route:
        - destination:
            host: {{ $t.host | quote }}
            port:
              number: {{ $t.upstreamPort }}
{{- end }}

{{/* ════════════════════════════════════════════════════════
     TLS-passthrough resources (secman, fluentbit и т.п.)
   ════════════════════════════════════════════════════════ */}}
{{- range $t := $tlsTargets }}
---
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: {{ include "ozone.fullname" $ }}-egress-to-{{ $t.name }}
  namespace: {{ $ns }}
  labels:
    {{- include "ozone.labels" $ | nindent 4 }}
spec:
  host: {{ $gwSvc }}
  subsets:
    - name: {{ $t.name }}
      trafficPolicy:
        portLevelSettings:
          - port:
              number: {{ $t.listener }}
            tls:
              mode: ISTIO_MUTUAL
              sni: {{ $t.host | quote }}
---
apiVersion: networking.istio.io/v1beta1
kind: VirtualService
metadata:
  name: {{ include "ozone.fullname" $ }}-egress-{{ $t.name }}
  namespace: {{ $ns }}
  labels:
    {{- include "ozone.labels" $ | nindent 4 }}
spec:
  hosts:
    - {{ $t.host | quote }}
  gateways:
    - mesh
    - {{ $gwRef }}
  tls:
    - match:
        - port: {{ $t.port }}
          sniHosts:
            - {{ $t.host | quote }}
          gateways:
            - mesh
      route:
        - destination:
            host: {{ $gwSvc }}
            subset: {{ $t.name }}
            port:
              number: {{ $t.listener }}
    - match:
        - port: {{ $t.listener }}
          sniHosts:
            - {{ $t.host | quote }}
          gateways:
            - {{ $gwRef }}
      route:
        - destination:
            host: {{ $t.host | quote }}
            port:
              number: {{ $t.port }}
{{- end }}

{{/* ════════════════════════════════════════════════════════
     PostgreSQL (TCP+TLS passthrough)
   ════════════════════════════════════════════════════════ */}}
{{- range $t := $pgTargets }}
---
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: {{ include "ozone.fullname" $ }}-egress-to-{{ $t.name }}
  namespace: {{ $ns }}
  labels:
    {{- include "ozone.labels" $ | nindent 4 }}
spec:
  host: {{ $gwSvc }}
  subsets:
    - name: {{ $t.name }}
      trafficPolicy:
        portLevelSettings:
          - port:
              number: 15432
            tls:
              mode: ISTIO_MUTUAL
              sni: {{ $t.host | quote }}
---
apiVersion: networking.istio.io/v1beta1
kind: VirtualService
metadata:
  name: {{ include "ozone.fullname" $ }}-egress-{{ $t.name }}
  namespace: {{ $ns }}
  labels:
    {{- include "ozone.labels" $ | nindent 4 }}
spec:
  hosts:
    - {{ $t.host | quote }}
  gateways:
    - mesh
    - {{ $gwRef }}
  tcp:
    - match:
        - port: {{ $t.port }}
          gateways:
            - mesh
      route:
        - destination:
            host: {{ $gwSvc }}
            subset: {{ $t.name }}
            port:
              number: 15432
    - match:
        - port: 15432
          gateways:
            - {{ $gwRef }}
      route:
        - destination:
            host: {{ $t.host | quote }}
            port:
              number: {{ $t.port }}
{{- end }}

{{- end }}





{{/*
Expand the name of the chart.
*/}}
{{- define "ozone.name" -}}
{{- default .Chart.Name .Values.nameOverride | trunc 63 | trimSuffix "-" }}
{{- end }}

{{/*
tcpSocket liveness/readiness probes on the given RPC port.
Намеренно НЕ кворум-зависимые: порт RPC биндится до выбора лидера Raft, поэтому
probe зелёный и при старте с нуля (параллельный bootstrap), и при апгрейде.
Сериализацию rolling-upgrade обеспечивает <role>.releaseOrdinal + проверка
`ozone admin {scm,om} roles` в scripts/rolling-upgrade.sh, а не readiness-гейт.
Usage: include "ozone.rpcProbes" (dict "probes" .Values.om.probes "port" .Values.om.service.rpcPort)
*/}}
{{- define "ozone.rpcProbes" -}}
{{- $p := .probes -}}
{{- if and $p $p.liveness $p.liveness.enabled }}
livenessProbe:
  tcpSocket:
    port: {{ .port }}
  initialDelaySeconds: {{ $p.liveness.initialDelaySeconds }}
  periodSeconds: {{ $p.liveness.periodSeconds }}
  timeoutSeconds: {{ $p.liveness.timeoutSeconds }}
  failureThreshold: {{ $p.liveness.failureThreshold }}
{{- end }}
{{- if and $p $p.readiness $p.readiness.enabled }}
readinessProbe:
  tcpSocket:
    port: {{ .port }}
  initialDelaySeconds: {{ $p.readiness.initialDelaySeconds }}
  periodSeconds: {{ $p.readiness.periodSeconds }}
  timeoutSeconds: {{ $p.readiness.timeoutSeconds }}
  failureThreshold: {{ $p.readiness.failureThreshold }}
{{- end }}
{{- end }}

{{/*
Create a default fully qualified app name.
We truncate at 63 chars because some Kubernetes name fields are limited to this (by the DNS naming spec).
If release name contains chart name it will be used as a full name.
*/}}
{{- define "ozone.fullname" -}}
{{- if .Values.fullnameOverride }}
{{- .Values.fullnameOverride | trunc 63 | trimSuffix "-" }}
{{- else }}
{{- $name := default .Chart.Name .Values.nameOverride }}
{{- if contains $name .Release.Name }}
{{- .Release.Name | trunc 63 | trimSuffix "-" }}
{{- else }}
{{- printf "%s-%s" .Release.Name $name | trunc 63 | trimSuffix "-" }}
{{- end }}
{{- end }}
{{- end }}

{{/*
Create chart name and version as used by the chart label.
*/}}
{{- define "ozone.chart" -}}
{{- printf "%s-%s" .Chart.Name .Chart.Version | replace "+" "_" | trunc 63 | trimSuffix "-" }}
{{- end }}

