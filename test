Шаблон templates/resourcequota.yaml:                                                                                                                                                                                                                  
  {{- if and .Values.resourceQuota.enabled (eq .Values.global.storage.mode "storageClass") }}                                                                                                                                                           
  {{- $dnDisks := len .Values.global.storage.storageClass.datanode.diskIndices | int }}                                                                                                                                                                 
  {{- $pvcCount := add                                                                 
      (mul (.Values.om.replicas | int) 1)                                                                                                                                                                                                               
      (mul (.Values.scm.replicas | int) 1)
      (mul (.Values.datanode.replicas | int) $dnDisks) }}                                                                                                                                                                                               
  {{- $quota := .Values.resourceQuota.extraPVCs | int | add $pvcCount }}                                                                                                                                                                                
  apiVersion: v1                                                        
  kind: ResourceQuota                                                                                                                                                                                                                                   
  metadata:          
    name: {{ include "ozone.fullname" . }}-storage                                                                                                                                                                                                      
    namespace: {{ include "ozone.namespace" . }}  
    labels:                                                                                                                                                                                                                                             
      {{- include "ozone.labels" . | nindent 4 }}
  spec:                                                                                                                                                                                                                                                 
    hard:         
      persistentvolumeclaims: "{{ $quota }}"
  {{- end }}
                                                                                                                                                                                                                                                        
  В values:
  resourceQuota:                                                                                                                                                                                                                                        
    enabled: false
    # Extra PVCs beyond what the chart itself creates (e.g. for pre-existing claims)
    extraPVCs: 0          



