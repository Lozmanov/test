echo ">>> /usr/bin/env"
copy_with_deps /usr/bin/env
mkdir -p "${ROOTFS}/usr/bin"
[ -e "${ROOTFS}/usr/bin/env" ] || ln -sf "$(readlink -f /usr/bin/env)" "${ROOTFS}/usr/bin/env"



RUN python2 -c "
path = '${HUE_HOME}/desktop/core/src/desktop/lib/conf.py'
src = open(path).read()
old = 'def coerce_password_from_script(raw):'
new = 'def coerce_password_from_script(raw):\n  if not raw or not raw.strip():\n    return \"\"'
assert old in src, 'patch target not found in ' + path
open(path, 'w').write(src.replace(old, new, 1))
print('patched: ' + path)
"
