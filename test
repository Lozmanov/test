  NS=dev-lozmanov
  PROM=$(kubectl -n $NS get pod -l component=prometheus -o jsonpath='{.items[0].metadata.name}')

  # 1) Статус всех таргетов: job / scrapeUrl / health / ошибка
  kubectl -n $NS exec $PROM -c prometheus -- wget -qO- 'http://localhost:9090/api/v1/targets?state=active' \
    | python3 -c 'import sys,json; [print(f"{t[\"labels\"].get(\"job\"):16} {t[\"health\"]:5} {t[\"scrapeUrl\"]:45} {t[\"lastError\"][:60]}") for t in json.load(sys.stdin)["data"]["activeTargets"]]'

  echo "=== есть ли вообще cluster на |9882| (headless datanode http) ==="
  kubectl -n $NS exec $PROM -c istio-proxy -- pilot-agent request GET clusters 2>/dev/null \
    | grep -oE 'outbound\|9882\|[^:]*' | sort -u

  echo "=== для сравнения: cluster на recon http-порт 9888 (ClusterIP) ==="
  kubectl -n $NS exec $PROM -c istio-proxy -- pilot-agent request GET clusters 2>/dev/null \
    | grep -oE 'outbound\|9888\|[^:]*' | sort -u
