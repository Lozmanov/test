copy_executable() {
    local f="$1"
    [ -f "$f" ] || return 0
    mkdir -p "${ROOTFS}$(dirname "$f")"
    [ -f "${ROOTFS}${f}" ] || cp -p "$f" "${ROOTFS}${f}"
    echo "  copied ${f}"
    if [ "$(head -c2 "$f" 2>/dev/null)" = "#!" ]; then
        local interp
        interp="$(head -n1 "$f" | sed 's/^#![[:space:]]*//' | awk '{print $1}')"
        if [ -n "$interp" ] && [ "$interp" != "$f" ]; then
            copy_executable "$interp"
        fi
    fi
    ldd "$f" 2>/dev/null | awk '/=>/ {print $3} (NF==2 && $1 ~ /^\//) {print $1}' | while read -r lib; do
        [ -f "$lib" ] || continue
        mkdir -p "${ROOTFS}$(dirname "$lib")"
        [ -f "${ROOTFS}${lib}" ] || cp -p "$lib" "${ROOTFS}${lib}"
    done || true
}

# ── 3b. coreutils: du / df ───────────────────────────────────────────────────
echo ">>> coreutils (du, df)"
for tool in du df; do
    bin="$(command -v "$tool" 2>/dev/null || true)"
    if [ -z "$bin" ]; then
        echo "  WARNING: ${tool} не найден в билдере"
        continue
    fi
    real="$(readlink -f "$bin")"
    copy_executable "$real"
    if [ "$bin" != "$real" ]; then
        mkdir -p "${ROOTFS}$(dirname "$bin")"
        ln -sf "$real" "${ROOTFS}${bin}"
        echo "  symlink ${bin} -> ${real}"
    fi
done
