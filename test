def createBucketAndGetS3Secret() {
    withCredentials([string(credentialsId: "$tokenCred", variable: 'token')]) {
        sh "oc login --token=${token} --server=$clusterURL"
        sh "oc project $params.OS_PROJECT"

        def cliPod = sh(
            script: "oc get pod -l component=cli -o jsonpath='{.items[0].metadata.name}'",
            returnStdout: true
        ).trim()
        echo "CLI pod: ${cliPod}"

        // Создаём S3-volume (s3v — дефолтный volume для S3 в Ozone), игнорируем ошибку если уже существует
        sh "oc exec ${cliPod} -- ozone sh volume create /s3v || true"

        // Создаём бакет
        sh "oc exec ${cliPod} -- ozone sh bucket create /s3v/${params.BUCKET_NAME}"

        // Получаем S3-секрет для подключения
        def s3Secret = sh(
            script: "oc exec ${cliPod} -- ozone s3 getsecret",
            returnStdout: true
        ).trim()

        writeFile file: 'bucket-info.txt', text: """\
Bucket created: /s3v/${params.BUCKET_NAME}
Namespace:      ${params.OS_PROJECT}
Cluster:        ${clusterURL}
"""
        writeFile file: 's3-credentials.txt', text: s3Secret

        archiveArtifacts artifacts: 'bucket-info.txt, s3-credentials.txt', fingerprint: true
    }
}
