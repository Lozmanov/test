{{- if and .Values.prometheus.enabled .Values.prometheus.podCIDR }}
---
apiVersion: networking.istio.io/v1beta1
kind: ServiceEntry
metadata:
  name: {{ include "ozone.fullname" . }}-pod-network
  namespace: {{ include "ozone.namespace" . }}
  labels:
    {{- include "ozone.labels" . | nindent 4 }}
spec:
  hosts:
    - pod-network.cluster.local
  addresses:
    - {{ .Values.prometheus.podCIDR }}
  ports:
    {{- if .Values.om.enabled }}
    - number: {{ .Values.om.service.port }}
      name: http-om
      protocol: HTTP
    {{- end }}
    {{- if .Values.scm.enabled }}
    - number: {{ .Values.scm.service.port }}
      name: http-scm
      protocol: HTTP
    {{- end }}
    {{- if .Values.datanode.enabled }}
    - number: {{ .Values.datanode.service.prometheusPort }}
      name: http-datanode
      protocol: HTTP
    {{- end }}
    {{- if .Values.s3g.enabled }}
    - number: {{ .Values.s3g.service.rest.port }}
      name: http-s3g
      protocol: HTTP
    {{- end }}
    {{- if .Values.recon.enabled }}
    - number: {{ .Values.recon.service.port }}
      name: http-recon
      protocol: HTTP
    {{- end }}
  resolution: NONE
  location: MESH_EXTERNAL
{{- end }}




{{- if .Values.prometheus.podCIDR }}
        - "./pod-network.cluster.local"
        {{- end }}


