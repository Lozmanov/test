{{/*
Fluent-bit sidecar container. Tails <logDir>/<component>.log
(and <logDir>/<component>-audit.log when component has an audit logger)
from the shared emptyDir and ships them to the external collector.
*/}}
{{- define "ozone.fluentbit.container" -}}
{{- $ctx := .ctx -}}
{{- $logDir := $ctx.Values.fluentBit.logDir -}}
{{- $component := .component -}}
{{- $hasAudit := has $component (list "om" "scm" "datanode" "s3g") -}}
- name: fluent-bit
  image: "{{ tpl $ctx.Values.fluentBit.image.registry $ctx }}/{{ tpl $ctx.Values.fluentBit.image.repository $ctx }}:{{ tpl $ctx.Values.fluentBit.image.tag $ctx }}"
  imagePullPolicy: Always
  env:
    - name: FLUENTBIT_COMPONENT
      value: {{ $component | quote }}
    - name: FLUENTBIT_TECH_LOG_PATH
      value: {{ printf "%s/%s.log" $logDir $component | quote }}
    - name: FLUENTBIT_AUDIT_LOG_PATH
      {{- if $hasAudit }}
      value: {{ printf "%s/%s-audit.log" $logDir $component | quote }}
      {{- else }}
      value: {{ printf "%s/.no-audit" $logDir | quote }}
      {{- end }}
    - name: POD_NAMESPACE
      value: {{ include "ozone.namespace" $ctx | quote }}
    - name: APP_ID
      value: {{ $ctx.Values.fluentBit.appId | quote }}
  ports:
    - containerPort: {{ $ctx.Values.fluentBit.fluentMetricsPort }}
      name: fb-metrics
      protocol: {{ $ctx.Values.fluentBit.fluentMetricsProtocol | default "TCP" }}
  livenessProbe:
    httpGet:
      path: /api/v1/health
      port: fb-metrics
    initialDelaySeconds: 10
    periodSeconds: 30
  {{- include "ozone.containerSecurityContext" $ctx | nindent 2 }}
  {{- with $ctx.Values.fluentBit.resources }}
  resources:
    {{- toYaml . | nindent 4 }}
  {{- end }}
  volumeMounts:
    - name: fluent-bit-config
      mountPath: /fluent-bit/etc/
    - name: fluent-bit-tmp
      mountPath: /tmp
    - name: ozone-logs
      mountPath: {{ $logDir }}
{{- end -}}

{{/*
Volumes required by fluent-bit sidecar + the shared log dir.
*/}}
{{- define "ozone.fluentbit.volumes" -}}
- name: fluent-bit-config
  configMap:
    name: fluent-bit-ozone-config
    defaultMode: 256
- name: fluent-bit-tmp
  emptyDir: {}
- name: ozone-logs
  emptyDir: {}
{{- end -}}

{{/*
VolumeMount for the main Ozone container, pointing at the shared log dir.
The main container must write to fluentBit.logDir so fluent-bit can tail
those files from its own mount of the same emptyDir.
*/}}
{{- define "ozone.fluentbit.logsMount" -}}
- name: ozone-logs
  mountPath: {{ $.Values.fluentBit.logDir }}
{{- end -}}

{{/*
Per-host TLS config для Istio Ingress Gateway. JSON-список компонентов с TLS
(включён компонент+ingress, secman.enabled, ingress.secman.tls=true).
Поле mutual (ingress.secman.mutual) → MUTUAL+CA, иначе SIMPLE.
*/}}
{{- define "ozone.ingressGateway.tlsHosts" -}}
{{- $ctx := . -}}
{{- $out := list -}}
{{- range $c := (list "recon" "s3g" "hue" "prometheus") -}}
{{- $cv := index $ctx.Values $c -}}
{{- $tls := dig "secman" "tls" false $cv.ingress -}}
{{- if and $cv.enabled $cv.ingress.enabled $ctx.Values.secman.enabled $tls -}}
{{- $host := include "ozone.ingress.host" (dict "host" $cv.ingress.host "component" $cv.serviceName "ctx" $ctx) -}}
{{- $out = append $out (dict
      "name" $cv.serviceName
      "host" $host
      "mutual" (dig "secman" "mutual" false $cv.ingress)
      "certFile" (printf "/vault/secrets/%s-serverCert.pem" $cv.serviceName)
      "keyFile" (printf "/vault/secrets/%s-privateKey.pem" $cv.serviceName)
      "caFile" (printf "/vault/secrets/%s-caCert.pem" $cv.serviceName)) -}}
{{- end -}}
{{- end -}}
{{- $out | toJson -}}
{{- end -}}

{{/*
Vault Agent annotations для ingress gateway: cert+key+CA — всё из одной выдачи
SBERCA fetch (secman.certPath, common_name=<host>): .Data.certificate /
.Data.private_key / .Data.issuing_ca.
*/}}
{{- define "ozone.ingressGateway.vaultAnnotations" -}}
{{- $ctx := . -}}
{{- $fetch := include "ozone.secman.certPath" $ctx -}}
{{- range $h := (include "ozone.ingressGateway.tlsHosts" $ctx | fromJsonArray) }}
vault.hashicorp.com/agent-inject-secret-{{ $h.name }}-serverCert.pem: 'true'
vault.hashicorp.com/agent-inject-file-{{ $h.name }}-serverCert.pem: {{ $h.name }}-serverCert.pem
vault.hashicorp.com/secret-volume-path-{{ $h.name }}-serverCert.pem: /vault/secrets/
vault.hashicorp.com/agent-inject-perms-{{ $h.name }}-serverCert.pem: '0400'
vault.hashicorp.com/agent-inject-template-{{ $h.name }}-serverCert.pem: |
  {{`{{- with secret `}}"{{ $fetch }}" "common_name={{ $h.host }}" "alt_names={{ $h.host }}" "format=pem"{{` -}}`}}
  {{`{{ index .Data.certificate }}`}}
  {{`{{- end }}`}}
vault.hashicorp.com/agent-inject-secret-{{ $h.name }}-privateKey.pem: 'true'
vault.hashicorp.com/agent-inject-file-{{ $h.name }}-privateKey.pem: {{ $h.name }}-privateKey.pem
vault.hashicorp.com/secret-volume-path-{{ $h.name }}-privateKey.pem: /vault/secrets/
vault.hashicorp.com/agent-inject-perms-{{ $h.name }}-privateKey.pem: '0400'
vault.hashicorp.com/agent-inject-template-{{ $h.name }}-privateKey.pem: |
  {{`{{- with secret `}}"{{ $fetch }}" "common_name={{ $h.host }}" "alt_names={{ $h.host }}" "format=pem"{{` -}}`}}
  {{`{{ index .Data.private_key }}`}}
  {{`{{- end }}`}}
{{- if $h.mutual }}
vault.hashicorp.com/agent-inject-secret-{{ $h.name }}-caCert.pem: 'true'
vault.hashicorp.com/agent-inject-file-{{ $h.name }}-caCert.pem: {{ $h.name }}-caCert.pem
vault.hashicorp.com/secret-volume-path-{{ $h.name }}-caCert.pem: /vault/secrets/
vault.hashicorp.com/agent-inject-perms-{{ $h.name }}-caCert.pem: '0400'
vault.hashicorp.com/agent-inject-template-{{ $h.name }}-caCert.pem: |
  {{`{{- with secret `}}"{{ $fetch }}" "common_name={{ $h.host }}" "alt_names={{ $h.host }}" "format=pem"{{` -}}`}}
  {{`{{ index .Data.issuing_ca }}`}}
  {{`{{- end }}`}}
{{- end }}
{{- end -}}
{{- end -}}

{{/*
CN клиентского сертификата egress gateway. Service Manager валидирует
принадлежность домена стенду АС (/check/stand), поэтому CN — СВОЙ домен
(как у ingress-хостов), а не хост upstream'а. Эталон sdp-compute-builder
делает так же: egress использует серт своего ingress-хоста.
*/}}
{{- define "ozone.egressGateway.clientCommonName" -}}
{{- if .Values.istio.egressGateway.tls.clientCommonName -}}
{{- .Values.istio.egressGateway.tls.clientCommonName -}}
{{- else -}}
{{- printf "egressgateway-ozone-%s.%s" (include "ozone.namespace" .) .Values.global.ingress.baseDomain -}}
{{- end -}}
{{- end -}}

{{/*
Vault Agent annotations для egress gateway: ОДНА тройка клиентский
cert + key + CA из одной выдачи SBERCA fetch (secman.certPath,
common_name = ozone.egressGateway.clientCommonName): .Data.certificate /
.Data.private_key / .Data.issuing_ca — общая для всех mTLS-origination
upstream'ов. Так же, как на ingress gateway; KV для CA не используется.
Одинаковые аргументы `with secret` дедуплицируются vault-agent'ом в один
вызов, поэтому cert/key/ca консистентны между собой.
*/}}
{{- define "ozone.egressGateway.vaultAnnotations" -}}
{{- $ctx := . -}}
{{- $s := $ctx.Values.istio.egressGateway.tls.secman -}}
{{- if and $ctx.Values.secman.enabled (or $s.rangerMtls $s.fluentbitMtls $s.prometheusRwMtls $s.federateMtls) -}}
{{- $fetch := include "ozone.secman.certPath" $ctx -}}
{{- $cn := include "ozone.egressGateway.clientCommonName" $ctx }}
vault.hashicorp.com/agent-inject-secret-egressgateway-client-cert: 'true'
vault.hashicorp.com/agent-inject-template-egressgateway-client-cert: |
  {{`{{- with secret `}}"{{ $fetch }}" "common_name={{ $cn }}" "alt_names={{ $cn }}" "format=pem"{{` -}}`}}
  {{`{{ index .Data.certificate }}`}}
  {{`{{- end }}`}}
vault.hashicorp.com/agent-inject-perms-egressgateway-client-cert: '0400'
vault.hashicorp.com/agent-inject-secret-egressgateway-client-key: 'true'
vault.hashicorp.com/agent-inject-template-egressgateway-client-key: |
  {{`{{- with secret `}}"{{ $fetch }}" "common_name={{ $cn }}" "alt_names={{ $cn }}" "format=pem"{{` -}}`}}
  {{`{{ index .Data.private_key }}`}}
  {{`{{- end }}`}}
vault.hashicorp.com/agent-inject-perms-egressgateway-client-key: '0400'
vault.hashicorp.com/agent-inject-secret-egressgateway-ca: 'true'
vault.hashicorp.com/agent-inject-template-egressgateway-ca: |
  {{`{{- with secret `}}"{{ $fetch }}" "common_name={{ $cn }}" "alt_names={{ $cn }}" "format=pem"{{` -}}`}}
  {{`{{ index .Data.issuing_ca }}`}}
  {{`{{- end }}`}}
vault.hashicorp.com/agent-inject-perms-egressgateway-ca: '0400'
{{/*
  Per-target override CA для проверки upstream'а: статичный PEM-бандл из
  KV (secman.path, ключ <name>CaKey). Нужен, когда upstream подписан НЕ
  тем SBERCA-движком, который выпускает наши серты (иначе
  CERTIFICATE_VERIFY_FAILED на origination).
*/}}
{{- $kv := $ctx.Values.secman.path -}}
{{- $caMap := dict "ranger" $s.rangerCaKey
                   "fluentbit" $s.fluentbitCaKey
                   "prometheus-rw" $s.prometheusRwCaKey
                   "federate" $s.federateCaKey -}}
{{- range $name, $vaultKey := $caMap -}}
{{- if $vaultKey }}
vault.hashicorp.com/agent-inject-secret-egressgateway-{{ $name }}-upstream-ca: 'true'
vault.hashicorp.com/agent-inject-template-egressgateway-{{ $name }}-upstream-ca: |
  {{`{{- with secret `}}"{{ $kv }}"{{` -}}`}}
  {{`{{ index .Data.`}}{{ $vaultKey }}{{` }}`}}
  {{`{{- end }}`}}
vault.hashicorp.com/agent-inject-perms-egressgateway-{{ $name }}-upstream-ca: '0400'
{{- end -}}
{{- end -}}
{{- end -}}
{{- end -}}

{{/*
Resolve egress gateway hostname (Service FQDN) for DestinationRule subsets.
*/}}
{{- define "ozone.egressGateway.fqdn" -}}
{{ printf "istio-egressgateway-%s.%s.svc.%s" .Values.istio.egressGateway.selectorLabel (include "ozone.namespace" .) .Values.global.clusterDomain }}
{{- end -}}

{{- define "ozone.fluentbit.log4jOpts" -}}
{{- $confDir := "/ozone/etc/hadoop" -}}
{{- $hasAudit := has .component (list "om" "scm" "datanode" "s3g") -}}
