exec /bin/oauth2-proxy \                                                                                                                                                                                                
  --provider=htpasswd \                                                                                                                                                                                                 
  --htpasswd-file={{ .Values.recon.auth.htpasswdPath }} \                                                                                                                                                               
  --upstream=http://127.0.0.1:{{ .Values.recon.service.port }} \                                                                                                                                                        
  --http-address=0.0.0.0:19888 \                                                                                                                                                                                        
  --cookie-secret=$(openssl rand -hex 16) \                                                                                                                                                                             
  --cookie-secure=false \                                                                                                                                                                                               
  --email-domain=*   
