def waitForOzoneReady() {
    withCredentials([string(credentialsId: "$tokenCred", variable: 'token')]) {
        sh "oc login --token=${token} --server=$clusterURL"
        sh "oc project $params.OS_PROJECT"

        // Ждём Ready для всех критичных компонентов (таймаут 5 мин на каждый)
        sh "oc wait pod -l component=om       --for=condition=Ready --timeout=300s"
        sh "oc wait pod -l component=scm      --for=condition=Ready --timeout=300s"
        sh "oc wait pod -l component=datanode --for=condition=Ready --timeout=300s"
        sh "oc wait pod -l component=s3g      --for=condition=Ready --timeout=300s"
        sh "oc wait pod -l component=cli      --for=condition=Ready --timeout=300s"

        def cliPod = sh(
            script: "oc get pod -l component=cli -o jsonpath='{.items[0].metadata.name}'",
            returnStdout: true
        ).trim()
        echo "CLI pod: ${cliPod}"

        // Поллим safemode — кластер считается готовым когда safemode OFF
        // Попытки каждые 15 сек, максимум 10 минут (40 попыток)
        def maxRetries = 40
        def ready = false
        for (int i = 0; i < maxRetries; i++) {
            def status = sh(
                script: "oc exec ${cliPod} -- ozone admin safemode status 2>&1 || true",
                returnStdout: true
            ).trim()
            echo "Safemode status [${i + 1}/${maxRetries}]: ${status}"
            if (status.contains('Safemode is OFF')) {
                ready = true
                break
            }
            if (i < maxRetries - 1) {
                sleep(time: 15, unit: 'SECONDS')
            }
        }
        if (!ready) {
            error("Ozone не вышел из safe mode в течение отведённого времени")
        }
    }
}


stage('Wait for Ozone Ready') {
            when {
                expression { params.ACTION == 'INSTALL_OZONE' }
            }
            steps {
                script {
                    echo "Waiting for all Ozone components to be ready"
                    funclib.waitForOzoneReady()
                }
            }
        }



