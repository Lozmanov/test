    # Require nginx.ingress.kubernetes.io/whitelist-source-range annotation on S3G Ingress.
    # Applies on CREATE and UPDATE.
    requireIngressWhitelistSourceRange: false
    # If non-empty, also validates that the annotation value exactly matches this string.
    # Leave empty to only check presence.
    expectedWhitelistSourceRange: ""



    {{- if and .Values.s3g.enabled .Values.s3g.ingress.enabled .Values.kubelatte.scope.requireIngressWhitelistSourceRange }}
    - name: require-ingress-whitelist-source-range
      match:
        kinds:
          - apiGroups:
              - networking.k8s.io
            kinds:
              - Ingress
        namespaces:
          - {{ include "ozone.namespace" . }}
        operations:
          - CREATE
          - UPDATE
      rule:
        rego: |
          package kubelatte
          deny[msg] {
            not input.metadata.annotations["nginx.ingress.kubernetes.io/whitelist-source-range"]
            msg := "[ozone] S3G Ingress must have nginx.ingress.kubernetes.io/whitelist-source-range annotation set."
          }
          {{- if .Values.kubelatte.scope.expectedWhitelistSourceRange }}
          deny[msg] {
            val := input.metadata.annotations["nginx.ingress.kubernetes.io/whitelist-source-range"]
            val != {{ .Values.kubelatte.scope.expectedWhitelistSourceRange | quote }}
            msg := sprintf("[ozone] whitelist-source-range must be '{{ .Values.kubelatte.scope.expectedWhitelistSourceRange }}', got '%v'", [val])
          }
          {{- end }}
    {{- end }}
