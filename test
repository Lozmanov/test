echo ">>> coreutils (du, df)"
for tool in du df; do
    bin="$(command -v "$tool" 2>/dev/null || true)"
    if [ -z "$bin" ]; then
        echo "  WARNING: ${tool} не найден в билдере"
        continue
    fi
    real="$(readlink -f "$bin")"
    mkdir -p "${ROOTFS}$(dirname "$real")"
    [ -f "${ROOTFS}${real}" ] || cp -p "$real" "${ROOTFS}${real}"
    echo "  copied ${real}"
    ldd "$real" 2>/dev/null | awk '/=>/ {print $3} NF==2 && /^\// {print $1}' | while read -r lib; do
        [ -f "$lib" ] || continue
        mkdir -p "${ROOTFS}$(dirname "$lib")"
        [ -f "${ROOTFS}${lib}" ] || cp -p "$lib" "${ROOTFS}${lib}"
    done
    if [ "$bin" != "$real" ]; then
        mkdir -p "${ROOTFS}$(dirname "$bin")"
        ln -sf "$real" "${ROOTFS}${bin}"
        echo "  symlink ${bin} -> ${real}"
    fi
done
